{
  "manifest_version": 3,
  "name": "Playbypoint Availability Reader",
  "version": "0.4.2",
  "description": "Read Playbypoint booking availability by venue and show merged open intervals.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://book.propickle.com.au/*",
    "http://localhost:3007/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://book.propickle.com.au/*"],
      "js": ["providers/playbypointBookBox.js", "bookingDeepLink.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Read Playbypoint availability",
    "default_popup": "popup.html"
  }
}
