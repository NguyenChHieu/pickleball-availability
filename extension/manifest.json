{
  "manifest_version": 3,
  "name": "Pickleball Availability Reader",
  "version": "0.4.7",
  "description": "Read pickleball booking availability by venue and show merged open intervals.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://book.propickle.com.au/*",
    "https://clubspark.au/Broadway/*",
    "https://go.mindbodyonline.com/book/widgets/appointments/view/7b9803fef1/*",
    "https://playtomic.com/*",
    "https://houseofpickle.podplay.app/*",
    "https://wotso.hamletapp.co/*",
    "https://api.hamletapp.co/*",
    "https://data.hamletapp.co/*",
    "http://localhost:3007/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://book.propickle.com.au/*"],
      "js": ["providers/playbypointBookBox.js", "bookingDeepLink.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://clubspark.au/Broadway/*"],
      "js": ["providers/clubsparkBookByDate.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://go.mindbodyonline.com/book/widgets/appointments/view/7b9803fef1/*"],
      "js": ["providers/mindbodyAppointments.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://houseofpickle.podplay.app/book/darling-harbour*"],
      "js": ["providers/podplayDom.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://wotso.hamletapp.co/shop/experience/pyrmont*"],
      "js": ["providers/hamletExperience.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3007/s/*",
        "https://pickleball-availability.vercel.app/s/*",
        "https://pickleball-availability-git-main-henryngs-projects.vercel.app/s/*"
      ],
      "js": ["sharePageBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Read pickleball availability",
    "default_popup": "popup.html"
  }
}
